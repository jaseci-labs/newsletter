---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found · Jaseci Digest">
  <section class="notfound">
    <p class="eyebrow">404</p>
    <h1 class="display">Page not found.</h1>
    <p>The page you're looking for doesn't exist. Try the <a href="/issues">issues archive</a> or head <a href="/">home</a>.</p>
  </section>
</Layout>

<style>
  .notfound {
    margin: 4rem auto;
    max-width: var(--content-width);
  }
</style>
