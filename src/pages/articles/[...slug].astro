---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { Content } = await article.render();

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout
  title={`${article.data.title} · Jaseci Digest`}
  description={article.data.description}
>
  <article class="article">
    <header class="article-header">
      <p class="eyebrow">{article.data.eyebrow ?? 'Article'}</p>
      <h1 class="sr-only">{article.data.title}</h1>
    </header>

    <div class="article-body">
      <Content />
    </div>

    <nav class="article-nav">
      <a href="/issues">← Back to all issues</a>
    </nav>
  </article>
</Layout>

<style>
  .article {
    margin: 2rem auto;
    max-width: var(--content-width);
  }

  .article-header {
    margin: 2rem 0 1.5rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Deep-dive section heading (h2) — magazine treatment, all-caps, large. */
  .article-body :global(h2) {
    font-size: clamp(1.5rem, 3.2vw, 2.15rem);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 3.5rem 0 1.25rem;
  }

  /* Numbered chapter subheading (h3) — uppercase, big enough to be a section break. */
  .article-body :global(h3),
  .article-body :global(.numbered-subhead) {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 600;
    margin: 2.25rem 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .article-body :global(p) {
    margin: 0 0 1.1rem;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 1.1rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li) {
    margin: 0.4rem 0;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--rule);
    margin: 1.75rem 0;
    padding: 0.25rem 1.25rem;
    font-style: normal;
    font-size: 1.15rem;
    color: var(--text);
  }

  .article-body :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-body :global(.arrow-cta a),
  .article-body :global(.end-cta a) {
    text-decoration: none;
  }

  .article-nav {
    margin: 3rem 0 1rem;
  }
</style>
