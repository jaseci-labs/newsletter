---
interface Props {
  size?: number;
}

const { size = 32 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 40 44"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M20 1.5 L37.5 11.5 L37.5 32.5 L20 42.5 L2.5 32.5 L2.5 11.5 Z"
    stroke="currentColor"
    stroke-width="1.6"
    fill="none"
  />
  <path
    d="M25 14 L25 28 Q25 32 21 32 L17 32"
    stroke="var(--accent, currentColor)"
    stroke-width="1.8"
    fill="none"
    stroke-linecap="round"
  />
</svg>
