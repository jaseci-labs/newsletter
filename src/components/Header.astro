---
const nav = [
  { label: 'Issues', href: '/issues' },
  { label: 'Subscribe', href: '/#subscribe' },
  { label: 'About', href: '/about' },
  { label: 'Jaseci.org', href: 'https://www.jaseci.org', external: true },
];
---

<header class="site-header">
  <div class="container">
    <div class="brand-row">
      <a href="/" class="brand" aria-label="Jaseci Digest home">
        <img src="/logo.png" alt="" width="28" height="28" class="brand-logo" />
        <span class="brand-text">Jaseci Digest</span>
      </a>
    </div>
    <nav aria-label="Primary">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href} {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <hr class="header-rule" />
  </div>
</header>

<style>
  .site-header {
    padding-top: 1.5rem;
  }

  .brand-row {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text);
    text-decoration: none;
  }

  .brand:hover {
    color: var(--text);
    opacity: 0.85;
  }

  .brand-logo {
    display: block;
    width: 28px;
    height: 28px;
  }

  .brand-text {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.85rem;
    font-weight: 600;
  }

  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  nav li:nth-child(1) { text-align: left; }
  nav li:nth-child(2) { text-align: center; }
  nav li:nth-child(3) { text-align: center; }
  nav li:nth-child(4) { text-align: right; }

  nav a {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--text);
  }

  .header-rule {
    margin: 1rem 0 0;
    border: none;
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 540px) {
    nav ul {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    nav li:nth-child(3) { text-align: left; }
    nav li:nth-child(4) { text-align: right; }
    nav a {
      font-size: 0.78rem;
    }
  }
</style>
