# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; `.env.example` is committed as a template.
# Do NOT put real secrets in this file.

# Public site config (exposed to the browser at build time)
PUBLIC_SITE_URL=https://jasecidigest.com
PUBLIC_BUTTONDOWN_USERNAME=jaseci

# Server-side only — used by /api/subscribe to add subscribers + send welcome email.
# Generate at https://buttondown.com/settings/programming
BUTTONDOWN_API_KEY=
